# Copy to .env and adjust for local development
DJANGO_SECRET_KEY=change-me-in-production-use-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=bubblle
POSTGRES_USER=bubblle
POSTGRES_PASSWORD=bubblle
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

# Cookie security: set False for local HTTP; True behind HTTPS in production
SESSION_COOKIE_SECURE=0

# Public site URL for chat image links (required on HTTPS production)
# BUBBLLE_PUBLIC_BASE_URL=https://bubblle.me

# Optional: comma-separated full origins for CSRF (AWS ALB / custom domain)
# DJANGO_CSRF_TRUSTED_ORIGINS=https://chat.example.com

# AI chat bots (docker compose service: ai-agents)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
BUBBLLE_AI_BOTS_PER_BUBBLE=1
BUBBLLE_AI_REPLY_DELAY_MIN=10
BUBBLLE_AI_REPLY_DELAY_MAX=10
BUBBLLE_AI_REPLY_MIN_GAP=10
