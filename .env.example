# Copy to .env and adjust for local development
DJANGO_SECRET_KEY=change-me-in-production-use-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=bubblle
POSTGRES_USER=bubblle
POSTGRES_PASSWORD=bubblle
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

# Cookie security: set False for local HTTP; True behind HTTPS in production
SESSION_COOKIE_SECURE=0

# Optional: comma-separated full origins for CSRF (AWS ALB / custom domain)
# DJANGO_CSRF_TRUSTED_ORIGINS=https://chat.example.com
